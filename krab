#!/usr/bin/env bash
# krab: sandboxed claude using bubblewrap.
# https://github.com/dritory/krab
set -euo pipefail

KRAB_VERSION="1.0.0"

die() { echo "krab: $*" >&2; exit 1; }

# Load config. Precedence: env var > project .krab > ~/.config/krab/config.
load_config_file() {
    [ -f "$1" ] || return 0
    while IFS='=' read -r key value; do
        key=$(echo "$key" | xargs)
        [[ "$key" =~ ^#|^$ ]] && continue
        value=$(echo "$value" | xargs)
        case "$key" in
            KRAB_ENV)         KRAB_ENV="${KRAB_ENV:-$value}" ;;
            KRAB_ALLOW_WRITE) KRAB_ALLOW_WRITE="${KRAB_ALLOW_WRITE:-$value}" ;;
        esac
    done < "$1"
}

load_config() {
    # Global defaults first (lowest priority).
    load_config_file "${XDG_CONFIG_HOME:-$HOME/.config}/krab/config"

    # Project config overrides global (walk up from $PWD).
    local dir="$PWD"
    while [ "$dir" != "/" ]; do
        if [ -f "$dir/.krab" ]; then
            load_config_file "$dir/.krab"
            return
        fi
        dir=$(dirname "$dir")
    done
}
run_sandboxed() {
    local bwrap_args=(
        --ro-bind / /
        --dev /dev
        --proc /proc
        --bind /tmp /tmp
        --bind /var/tmp /var/tmp
        --unshare-pid
    )

    # Writable: $HOME (so claude can atomic-rename ~/.claude.json and
    # tools can write wherever they need) + project dir.
    bwrap_args+=(--bind "$HOME" "$HOME")
    [ "$PWD" = "$HOME" ] || bwrap_args+=(--bind "$PWD" "$PWD")

    # Lock down sensitive paths within writable $HOME.
    # NOTE: ~/.claude/.credentials.json is NOT read-only because claude
    # needs to write refreshed OAuth tokens back to it.
    for p in "$HOME/.ssh" "$HOME/.gnupg"; do
        [ -d "$p" ] && bwrap_args+=(--ro-bind "$p" "$p")
    done
    for p in "$HOME/.bashrc" "$HOME/.bash_history" "$HOME/.profile" "$HOME/.zshrc"; do
        [ -f "$p" ] && bwrap_args+=(--ro-bind "$p" "$p")
    done

    # Extra writable paths.
    if [ -n "${KRAB_ALLOW_WRITE:-}" ]; then
        IFS=':' read -ra extra <<< "$KRAB_ALLOW_WRITE"
        for p in "${extra[@]}"; do
            [ -e "$p" ] && bwrap_args+=(--bind "$p" "$p")
        done
    fi

    # Strip env vars matching these patterns unless explicitly allowed.
    local deny='(^AWS_|_SECRET|_TOKEN|_KEY|_PASSWORD|_CREDENTIAL)'
    local allow_csv="${KRAB_ENV:-}"
    while IFS='=' read -r name _; do
        if [[ "$name" =~ $deny ]]; then
            local keep=0
            if [ -n "$allow_csv" ]; then
                IFS=',' read -ra allow_list <<< "$allow_csv"
                for a in "${allow_list[@]}"; do
                    [ "$name" = "$a" ] && keep=1
                done
            fi
            [ "$keep" -eq 0 ] && bwrap_args+=(--unsetenv "$name")
        fi
    done < <(env)

    bwrap_args+=(--setenv KRAB 1 --chdir "$PWD" --)

    exec bwrap "${bwrap_args[@]}" "$@"
}

doctor() {
    local ok=0 fail=0
    check() {
        if "$@" >/dev/null 2>&1; then
            echo "  ok   $*"; ok=$((ok+1))
        else
            echo "  FAIL $*"; fail=$((fail+1))
        fi
    }
    check command -v bwrap
    check command -v claude
    # Quick sandbox smoke test.
    check bwrap --ro-bind / / --dev /dev --proc /proc -- true
    echo "$ok passed, $fail failed"
    [ "$fail" -eq 0 ]
}

usage() {
    cat <<EOF
krab $KRAB_VERSION — sandboxed claude

  krab [args]        claude with filesystem sandbox
  krab yolo [args]   sandbox + skip all permission prompts
  krab shell         sandboxed bash (for debugging)
  krab doctor        check bwrap and claude work
  krab version
  krab help-krab

Config (.krab file in project root, or env vars):
  KRAB_ENV             env vars to keep (comma-separated)
  KRAB_ALLOW_WRITE     extra writable paths (colon-separated)
EOF
}

command -v bwrap >/dev/null 2>&1 || die "bubblewrap not found (apt install bubblewrap)"

load_config

case "${1:-}" in
    yolo)       shift; run_sandboxed claude --dangerously-skip-permissions "$@" ;;
    shell)      shift; run_sandboxed bash "$@" ;;
    doctor)     doctor ;;
    version)    echo "krab $KRAB_VERSION"; claude --version ;;
    help-krab) usage ;;
    --)         shift; run_sandboxed claude "$@" ;;
    *)          run_sandboxed claude "$@" ;;
esac
