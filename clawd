#!/usr/bin/env bash
# clawd: sandboxed claude using bubblewrap.
# https://github.com/dritory/clawd
set -euo pipefail

CLAWD_VERSION="1.0.0"

die() { echo "clawd: $*" >&2; exit 1; }

# Load config. Precedence: env var > project .clawd > ~/.config/clawd/config.
load_config_file() {
    [ -f "$1" ] || return 0
    while IFS='=' read -r key value; do
        key=$(echo "$key" | xargs)
        [[ "$key" =~ ^#|^$ ]] && continue
        value=$(echo "$value" | xargs)
        case "$key" in
            CLAWD_ENV)         CLAWD_ENV="${CLAWD_ENV:-$value}" ;;
            CLAWD_ALLOW_WRITE) CLAWD_ALLOW_WRITE="${CLAWD_ALLOW_WRITE:-$value}" ;;
        esac
    done < "$1"
}

load_config() {
    # Global defaults first (lowest priority).
    load_config_file "${XDG_CONFIG_HOME:-$HOME/.config}/clawd/config"

    # Project config overrides global (walk up from $PWD).
    local dir="$PWD"
    while [ "$dir" != "/" ]; do
        if [ -f "$dir/.clawd" ]; then
            load_config_file "$dir/.clawd"
            return
        fi
        dir=$(dirname "$dir")
    done
}
run_sandboxed() {
    local bwrap_args=(
        --ro-bind / /
        --dev /dev
        --proc /proc
        --bind /tmp /tmp
        --bind /var/tmp /var/tmp
        --unshare-pid
    )

    # Writable: project dir + dev tool paths. Everything else in $HOME
    # stays read-only (other projects, dotfiles, shell rc, etc.).
    bwrap_args+=(--bind "$PWD" "$PWD")
    for p in \
        "$HOME/.claude" \
        "$HOME/.cache" \
        "$HOME/.local" \
        "$HOME/.config" \
        "$HOME/.npm" \
        "$HOME/.cargo" \
        "$HOME/.rustup" \
    ; do
        [ -e "$p" ] && bwrap_args+=(--bind "$p" "$p")
    done
    [ -e "$HOME/.claude.json" ] && bwrap_args+=(--bind "$HOME/.claude.json" "$HOME/.claude.json")

    # Within the writable dirs, protect credentials.
    local creds="$HOME/.claude/.credentials.json"
    [ -f "$creds" ] && bwrap_args+=(--ro-bind "$creds" "$creds")
    for p in "$HOME/.ssh" "$HOME/.gnupg"; do
        [ -d "$p" ] && bwrap_args+=(--ro-bind "$p" "$p")
    done

    # Extra writable paths.
    if [ -n "${CLAWD_ALLOW_WRITE:-}" ]; then
        IFS=':' read -ra extra <<< "$CLAWD_ALLOW_WRITE"
        for p in "${extra[@]}"; do
            [ -e "$p" ] && bwrap_args+=(--bind "$p" "$p")
        done
    fi

    # Strip env vars matching these patterns unless explicitly allowed.
    local deny='(^AWS_|_SECRET|_TOKEN|_KEY|_PASSWORD|_CREDENTIAL)'
    local allow_csv="${CLAWD_ENV:-}"
    while IFS='=' read -r name _; do
        if [[ "$name" =~ $deny ]]; then
            local keep=0
            if [ -n "$allow_csv" ]; then
                IFS=',' read -ra allow_list <<< "$allow_csv"
                for a in "${allow_list[@]}"; do
                    [ "$name" = "$a" ] && keep=1
                done
            fi
            [ "$keep" -eq 0 ] && bwrap_args+=(--unsetenv "$name")
        fi
    done < <(env)

    bwrap_args+=(--setenv CLAWD 1 --chdir "$PWD" --)

    exec bwrap "${bwrap_args[@]}" "$@"
}

doctor() {
    local ok=0 fail=0
    check() {
        if "$@" >/dev/null 2>&1; then
            echo "  ok   $*"; ok=$((ok+1))
        else
            echo "  FAIL $*"; fail=$((fail+1))
        fi
    }
    check command -v bwrap
    check command -v claude
    # Quick sandbox smoke test.
    check bwrap --ro-bind / / --dev /dev --proc /proc -- true
    echo "$ok passed, $fail failed"
    [ "$fail" -eq 0 ]
}

usage() {
    cat <<EOF
clawd $CLAWD_VERSION — sandboxed claude

  clawd [args]        claude with filesystem sandbox
  clawd yolo [args]   sandbox + skip all permission prompts
  clawd shell         sandboxed bash (for debugging)
  clawd doctor        check bwrap and claude work
  clawd version
  clawd help-clawd

Config (.clawd file in project root, or env vars):
  CLAWD_ENV             env vars to keep (comma-separated)
  CLAWD_ALLOW_WRITE     extra writable paths (colon-separated)
EOF
}

command -v bwrap >/dev/null 2>&1 || die "bubblewrap not found (apt install bubblewrap)"

load_config

case "${1:-}" in
    yolo)       shift; run_sandboxed claude --dangerously-skip-permissions "$@" ;;
    shell)      shift; run_sandboxed bash "$@" ;;
    doctor)     doctor ;;
    version)    echo "clawd $CLAWD_VERSION"; claude --version ;;
    help-clawd) usage ;;
    --)         shift; run_sandboxed claude "$@" ;;
    *)          run_sandboxed claude "$@" ;;
esac
